    {
      "name": "Get Sale By Id",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "const data = json.data || {};",
              "const sale = data.sale || data.Sale;",
              "const saleId = sale ? (sale.id || sale.Id) : null;",
              "const firstItem = sale && sale.items ? sale.items[0] : sale && sale.Items ? sale.Items[0] : null;",
              "const itemId = firstItem ? (firstItem.id || firstItem.Id) : null;",
              "",
              "if (saleId) {",
              "  pm.collectionVariables.set('sale_id', saleId);",
              "}",
              "",
              "if (itemId) {",
              "  pm.collectionVariables.set('item_id', itemId);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{base_url}}/api/sales/{{sale_id}}",
        "description": "Busca uma venda pelo ID. O script atualiza `sale_id` e `item_id` com base no retorno."
      },
      "response": []
