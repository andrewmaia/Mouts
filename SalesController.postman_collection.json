  "item": [
    {
      "name": "Create Sale",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "const data = json.data || {};",
              "const saleId = data.saleId || data.SaleId || (data.sale && data.sale.id) || (data.Sale && data.Sale.Id);",
              "const sale = data.sale || data.Sale;",
              "const firstItem = sale && sale.items ? sale.items[0] : sale && sale.Items ? sale.Items[0] : null;",
              "const itemId = firstItem ? (firstItem.id || firstItem.Id) : null;",
              "",
              "if (saleId) {",
              "  pm.collectionVariables.set('sale_id', saleId);",
              "}",
              "",
              "if (itemId) {",
              "  pm.collectionVariables.set('item_id', itemId);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"saleNumber\": \"SALE-1001\",\n  \"saleDate\": \"2026-03-24T10:00:00Z\",\n  \"customerId\": \"{{customer_id}}\",\n  \"customerName\": \"Cliente Exemplo\",\n  \"branchId\": \"{{branch_id}}\",\n  \"branchName\": \"Filial Centro\",\n  \"items\": [\n    {\n      \"productId\": \"{{product_id_1}}\",\n      \"productName\": \"Produto A\",\n      \"quantity\": 2,\n      \"unitPrice\": 100.00\n    },\n    {\n      \"productId\": \"{{product_id_2}}\",\n      \"productName\": \"Produto B\",\n      \"quantity\": 4,\n      \"unitPrice\": 25.50\n    }\n  ]\n}"
